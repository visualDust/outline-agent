# Example environment variables. This file is not auto-loaded by the app.
# For local development, the main config path is `~/.outline-agent/config.yaml`.
# Exported environment variables override values from that YAML config.
# If you want to use this file directly, do something like:
#   set -a && source .env && set +a
# The app does not auto-load `.env` by itself.

OUTLINE_API_BASE_URL=
OUTLINE_API_KEY=
OUTLINE_WEBHOOK_SIGNING_SECRET=
OUTLINE_TIMEOUT_SECONDS=30
TRIGGER_MODE=mention
# Comma-separated mention aliases.
MENTION_ALIASES=
MENTION_ALIAS_FALLBACK_ENABLED=false
TRIGGER_ON_REPLY_TO_AGENT=true
ALLOWED_COLLECTION_IDS=
# Optional prompt override paths. Leave unset unless you actually created
# user override files under ~/.outline-agent/prompts/.
# SYSTEM_PROMPT_PATH=prompts/user/00_system.md
# PROMPT_PACK_DIR=prompts/user/packs
# INTERNAL_PROMPT_DIR=prompts/internal
SYSTEM_PROMPT_PACKS=outline_style
MODEL_REF=
ACTION_ROUTER_MODEL_REF=
MODEL_TIMEOUT_SECONDS=180
MAX_OUTPUT_TOKENS=800
MEMORY_ACTION_ENABLED=true
MEMORY_UPDATE_ENABLED=true
MEMORY_MODEL_REF=
DOCUMENT_UPDATE_ENABLED=true
DOCUMENT_UPDATE_MODEL_REF=
DOCUMENT_MEMORY_UPDATE_ENABLED=true
DOCUMENT_MEMORY_MODEL_REF=
TOOL_USE_ENABLED=true
TOOL_MODEL_REF=
TOOL_EXECUTION_MAX_ROUNDS=10
TOOL_EXECUTION_MAX_STEPS=6
TOOL_EXECUTION_CHUNK_SIZE=2
TOOL_SHELL_TIMEOUT_SECONDS=120
PROGRESS_COMMENT_ENABLED=true
PROGRESS_COMMENT_RECENT_ACTIONS=6
REACTION_ENABLED=true
REACTION_PROCESSING_EMOJI=👀
REACTION_DONE_EMOJI=👍
RELATED_DOCUMENTS_ENABLED=true
RELATED_DOCUMENT_LIMIT=3
RELATED_DOCUMENT_SEARCH_LIMIT=8
RELATED_DOCUMENT_EXCERPT_CHARS=600
RELATED_DOCUMENT_QUERY_MAX_CHARS=200
RELATED_DOCUMENT_MIN_QUERY_CHARS=4
SAME_DOCUMENT_COMMENT_LOOKUP_ENABLED=true
# Optional runtime root override. Defaults to ~/.outline-agent when unset.
# OUTLINE_AGENT_HOME=/tmp/outline-agent
# Optional config file override. Useful if you want multiple config profiles.
# OUTLINE_AGENT_CONFIG_PATH=/tmp/outline-agent/config.yaml
# Optional runtime path overrides. Relative values resolve from the active config root.
# WORKSPACE_ROOT=data/agents
# WEBHOOK_LOG_DIR=data/webhooks
# DEDUPE_STORE_PATH=data/processed_events.json
LOG_LEVEL=DEBUG
# LOG_FILE_PATH=logs/outline-agent.log
HOST=127.0.0.1
PORT=8787
DRY_RUN=false
